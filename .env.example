# Copy this file to ".env" and fill in your real keys.
# .env is git-ignored (see .gitignore) so keys never end up in the repo.

# TMDb API key -- free: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Google Gemini API key -- free: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Qdrant connection (default for local Docker -- usually leave unchanged)
QDRANT_URL=http://localhost:6333
